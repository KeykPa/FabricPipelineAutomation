{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Deploy All Workspaces",
      "type": "shell",
      "command": "python",
      "args": ["scripts/deploy_workspace.py"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Deploy Single Workspace",
      "type": "shell",
      "command": "python",
      "args": ["scripts/deploy_workspace.py", "--workspace-id", "${input:workspaceId}"],
      "problemMatcher": []
    },
    {
      "label": "Rename Workspaces (apply prefix)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/rename_workspaces.py", "--prefix", "${input:prefix}"],
      "problemMatcher": []
    },
    {
      "label": "Install Python Dependencies",
      "type": "shell",
      "command": "pip",
      "args": ["install", "-r", "requirements.txt"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    { "id": "workspaceId", "type": "promptString", "description": "Fabric workspace GUID" },
    { "id": "prefix", "type": "promptString", "description": "Workspace name prefix (e.g. GIZ)" }
  ]
}
