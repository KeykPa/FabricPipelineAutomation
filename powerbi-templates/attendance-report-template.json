{
  "reportMetadata": {
    "version": "5.0",
    "name": "Conference Attendance Report",
    "description": "Comprehensive attendance tracking and analytics for conferences and training events"
  },
  "pages": [
    {
      "name": "Overview",
      "displayName": "Attendance Overview",
      "width": 1280,
      "height": 720,
      "background": {
        "color": "#F5F5F5"
      },
      "visuals": [
        {
          "name": "TitleCard",
          "type": "textbox",
          "position": {"x": 20, "y": 20, "width": 1240, "height": 80},
          "config": {
            "text": "Conference Attendance Dashboard",
            "fontSize": 32,
            "fontWeight": "bold",
            "color": "#2C3E50",
            "alignment": "center"
          }
        },
        {
          "name": "TotalAttendees",
          "type": "card",
          "position": {"x": 20, "y": 120, "width": 280, "height": 140},
          "dataConfig": {
            "table": "conference_attendance",
            "measure": "COUNT(RegistrationID)",
            "displayName": "Total Registrations"
          },
          "formatting": {
            "fontSize": 48,
            "color": "#3498DB",
            "showLabel": true
          }
        },
        {
          "name": "AttendedCount",
          "type": "card",
          "position": {"x": 320, "y": 120, "width": 280, "height": 140},
          "dataConfig": {
            "table": "conference_attendance",
            "measure": "COUNT(RegistrationID)",
            "filter": "AttendanceStatus = 'Attended'",
            "displayName": "Attended"
          },
          "formatting": {
            "fontSize": 48,
            "color": "#27AE60",
            "showLabel": true
          }
        },
        {
          "name": "AttendanceRate",
          "type": "card",
          "position": {"x": 620, "y": 120, "width": 280, "height": 140},
          "dataConfig": {
            "table": "conference_attendance",
            "measure": "DIVIDE(COUNTROWS(FILTER(conference_attendance, [AttendanceStatus] = \"Attended\")), COUNTROWS(conference_attendance), 0)",
            "displayName": "Attendance Rate",
            "format": "0.0%"
          },
          "formatting": {
            "fontSize": 48,
            "color": "#E74C3C",
            "showLabel": true
          }
        },
        {
          "name": "AverageRating",
          "type": "card",
          "position": {"x": 920, "y": 120, "width": 280, "height": 140},
          "dataConfig": {
            "table": "conference_attendance",
            "measure": "AVERAGE(SessionRating)",
            "filter": "SessionRating <> BLANK()",
            "displayName": "Avg Session Rating",
            "format": "0.0"
          },
          "formatting": {
            "fontSize": 48,
            "color": "#F39C12",
            "showLabel": true
          }
        },
        {
          "name": "AttendanceByStatus",
          "type": "donutChart",
          "position": {"x": 20, "y": 280, "width": 400, "height": 420},
          "dataConfig": {
            "table": "conference_attendance",
            "category": "AttendanceStatus",
            "values": "COUNT(RegistrationID)",
            "displayName": "Attendance by Status"
          },
          "formatting": {
            "showLegend": true,
            "showDataLabels": true,
            "dataLabelFormat": "0",
            "colors": {
              "Attended": "#27AE60",
              "Registered": "#3498DB",
              "No-show": "#E74C3C",
              "Cancelled": "#95A5A6"
            }
          }
        },
        {
          "name": "SessionPopularity",
          "type": "barChart",
          "position": {"x": 440, "y": 280, "width": 400, "height": 420},
          "dataConfig": {
            "table": "conference_attendance",
            "category": "SessionName",
            "values": "COUNT(RegistrationID)",
            "displayName": "Session Popularity"
          },
          "formatting": {
            "showLegend": false,
            "showDataLabels": true,
            "dataLabelFormat": "0",
            "sortBy": "values",
            "sortOrder": "descending",
            "barColor": "#3498DB"
          }
        },
        {
          "name": "RatingDistribution",
          "type": "columnChart",
          "position": {"x": 860, "y": 280, "width": 400, "height": 420},
          "dataConfig": {
            "table": "conference_attendance",
            "category": "SessionRating",
            "values": "COUNT(RegistrationID)",
            "filter": "SessionRating <> BLANK()",
            "displayName": "Rating Distribution"
          },
          "formatting": {
            "showLegend": false,
            "showDataLabels": true,
            "dataLabelFormat": "0",
            "columnColor": "#F39C12"
          }
        }
      ]
    },
    {
      "name": "AttendeeList",
      "displayName": "Attendee List",
      "width": 1280,
      "height": 720,
      "background": {
        "color": "#F5F5F5"
      },
      "visuals": [
        {
          "name": "AttendeeTable",
          "type": "table",
          "position": {"x": 20, "y": 20, "width": 1240, "height": 680},
          "dataConfig": {
            "table": "conference_attendance",
            "columns": [
              {"name": "FirstName", "displayName": "First Name", "width": 120},
              {"name": "LastName", "displayName": "Last Name", "width": 120},
              {"name": "Email", "displayName": "Email", "width": 200},
              {"name": "Company", "displayName": "Company", "width": 180},
              {"name": "JobTitle", "displayName": "Job Title", "width": 180},
              {"name": "SessionName", "displayName": "Session", "width": 200},
              {"name": "AttendanceStatus", "displayName": "Status", "width": 100},
              {"name": "SessionRating", "displayName": "Rating", "width": 80}
            ]
          },
          "formatting": {
            "fontSize": 10,
            "headerFontSize": 12,
            "headerBold": true,
            "alternateRowColor": "#FFFFFF",
            "gridLines": true,
            "allowSearch": true,
            "allowFiltering": true,
            "allowSorting": true
          },
          "conditionalFormatting": [
            {
              "column": "AttendanceStatus",
              "rules": [
                {"value": "Attended", "backgroundColor": "#D5F5E3", "textColor": "#27AE60"},
                {"value": "No-show", "backgroundColor": "#FADBD8", "textColor": "#E74C3C"},
                {"value": "Cancelled", "backgroundColor": "#E8E8E8", "textColor": "#95A5A6"}
              ]
            },
            {
              "column": "SessionRating",
              "rules": [
                {"condition": ">= 4", "backgroundColor": "#D5F5E3", "textColor": "#27AE60"},
                {"condition": "<= 2", "backgroundColor": "#FADBD8", "textColor": "#E74C3C"}
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "SessionAnalytics",
      "displayName": "Session Analytics",
      "width": 1280,
      "height": 720,
      "background": {
        "color": "#F5F5F5"
      },
      "visuals": [
        {
          "name": "SessionPerformance",
          "type": "table",
          "position": {"x": 20, "y": 20, "width": 600, "height": 340},
          "dataConfig": {
            "table": "conference_attendance",
            "groupBy": "SessionName",
            "measures": [
              {"name": "Registrations", "expression": "COUNT(RegistrationID)"},
              {"name": "Attended", "expression": "COUNTROWS(FILTER(conference_attendance, [AttendanceStatus] = \"Attended\"))"},
              {"name": "Attendance %", "expression": "DIVIDE([Attended], [Registrations], 0)", "format": "0.0%"},
              {"name": "Avg Rating", "expression": "AVERAGE(SessionRating)", "format": "0.0"}
            ]
          },
          "formatting": {
            "fontSize": 10,
            "allowSorting": true
          }
        },
        {
          "name": "CompanyBreakdown",
          "type": "treemap",
          "position": {"x": 640, "y": 20, "width": 620, "height": 340},
          "dataConfig": {
            "table": "conference_attendance",
            "category": "Company",
            "values": "COUNT(RegistrationID)",
            "displayName": "Attendees by Company"
          },
          "formatting": {
            "showDataLabels": true,
            "dataLabelFormat": "0"
          }
        },
        {
          "name": "JobTitleDistribution",
          "type": "horizontalBarChart",
          "position": {"x": 20, "y": 380, "width": 600, "height": 320},
          "dataConfig": {
            "table": "conference_attendance",
            "category": "JobTitle",
            "values": "COUNT(RegistrationID)",
            "displayName": "Attendees by Job Title"
          },
          "formatting": {
            "showDataLabels": true,
            "sortBy": "values",
            "sortOrder": "descending"
          }
        },
        {
          "name": "CheckInTrend",
          "type": "lineChart",
          "position": {"x": 640, "y": 380, "width": 620, "height": 320},
          "dataConfig": {
            "table": "conference_attendance",
            "xAxis": "CheckInTime",
            "yAxis": "COUNT(RegistrationID)",
            "displayName": "Check-in Trend"
          },
          "formatting": {
            "showMarkers": true,
            "lineColor": "#3498DB"
          }
        }
      ]
    }
  ],
  "measures": [
    {
      "name": "Total Registrations",
      "expression": "COUNTROWS(conference_attendance)",
      "format": "0"
    },
    {
      "name": "Total Attended",
      "expression": "COUNTROWS(FILTER(conference_attendance, [AttendanceStatus] = \"Attended\"))",
      "format": "0"
    },
    {
      "name": "Attendance Rate",
      "expression": "DIVIDE([Total Attended], [Total Registrations], 0)",
      "format": "0.0%"
    },
    {
      "name": "No-Show Count",
      "expression": "COUNTROWS(FILTER(conference_attendance, [AttendanceStatus] = \"No-show\"))",
      "format": "0"
    },
    {
      "name": "Average Session Rating",
      "expression": "AVERAGE(conference_attendance[SessionRating])",
      "format": "0.0"
    },
    {
      "name": "Highly Rated Sessions",
      "expression": "COUNTROWS(FILTER(conference_attendance, [SessionRating] >= 4))",
      "format": "0"
    }
  ],
  "filters": [
    {
      "name": "DateRange",
      "table": "conference_attendance",
      "column": "SessionDate",
      "type": "dateRange",
      "scope": "report"
    },
    {
      "name": "Company",
      "table": "conference_attendance",
      "column": "Company",
      "type": "multiSelect",
      "scope": "report"
    },
    {
      "name": "AttendanceStatus",
      "table": "conference_attendance",
      "column": "AttendanceStatus",
      "type": "multiSelect",
      "scope": "report"
    }
  ],
  "theme": {
    "name": "Conference Theme",
    "dataColors": ["#3498DB", "#27AE60", "#F39C12", "#E74C3C", "#9B59B6", "#1ABC9C", "#34495E", "#95A5A6"],
    "backgroundColor": "#F5F5F5",
    "foregroundColor": "#2C3E50",
    "tableAccentColor": "#3498DB"
  }
}
