/// Direct connection to workspace lakehouse (automatic SSO)
/// No credentials needed - uses workspace identity
expression DatabaseQuery =
		let
		    // Connect to lakehouse in current workspace
		    // Fabric automatically resolves workspace context
		    source = Lakehouse.Contents(null),
		    navigation = source{[Id="ConferenceDataLakehouse",Kind="Lakehouse"]}[Data]
		in
		    navigation
	lineageTag: c6d00ea5-1e25-4df6-b247-8287a492cc06

	annotation PBI_IncludeFutureArtifacts = False

