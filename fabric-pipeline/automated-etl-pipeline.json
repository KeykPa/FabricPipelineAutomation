{
  "name": "Automated Conference Data ETL",
  "properties": {
    "activities": [
      {
        "name": "Load Conference Data",
        "type": "NotebookActivity",
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 2,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "notebookPath": "Load Conference Data",
          "parameters": {}
        }
      },
      {
        "name": "Refresh Semantic Model",
        "type": "ExecuteDataFlow",
        "dependsOn": [
          {
            "activity": "Load Conference Data",
            "dependencyConditions": [
              "Succeeded"
            ]
          }
        ],
        "policy": {
          "timeout": "0.12:00:00",
          "retry": 1,
          "retryIntervalInSeconds": 30
        },
        "typeProperties": {
          "dataFlowReference": {
            "referenceName": "ConferenceAttendanceSemanticModel",
            "type": "DataFlowReference"
          }
        }
      }
    ],
    "annotations": [],
    "description": "Automated pipeline to load conference attendance data from CSV to Delta table and refresh the semantic model for Power BI reports"
  }
}
